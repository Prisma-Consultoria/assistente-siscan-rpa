# =============================================================================
# SISCAN Dashboard — Sample do .env (modo SERVIDOR — VM dedicada)
# =============================================================================
# Utilizado pelo siscan-server-setup.sh --product dashboard na fase 4.
#
# Modo coberto: SERVIDOR — docker-compose.prd.dashboard.yml
#   - Sem serviço `db` local; conecta ao PostgreSQL externo via DATABASE_HOST
#   - Sync conecta ao banco do RPA via RPA_DATABASE_URL
#   - Deploy automático via GitHub Actions self-hosted runner
#
# Convenção:
#   HOST_* = caminhos absolutos Linux no servidor
#   demais  = parâmetros de runtime passados aos containers
# =============================================================================

# Produto gerenciado por esta instalação do assistente
SISCAN_PRODUCT=dashboard

# -----------------------------------------------------------------------------
# 1) APLICAÇÃO HTTP
# -----------------------------------------------------------------------------
# Porta TCP publicada no host. URL de acesso: http://<IP-DO-SERVIDOR>:5000
HOST_APP_EXTERNAL_PORT=5000

# Nível de log. Use INFO em produção; DEBUG apenas para diagnóstico temporário.
APP_LOG_LEVEL=INFO

# Workers Gunicorn. Servidor dedicado com 4 vCPUs: use 4.
WEB_CONCURRENCY=4

# Threads por worker do Gunicorn.
GUNICORN_THREADS=4

# Timeout do Gunicorn em segundos.
GUNICORN_TIMEOUT=120

# Chave de assinatura da sessão web (Flask). Obrigatória.
# Gere com: openssl rand -hex 32
SESSION_SECRET=

# -----------------------------------------------------------------------------
# 2) SENHAS DE USUÁRIOS INICIAIS
# -----------------------------------------------------------------------------
# Senha do administrador. Obrigatória na primeira execução.
ADMIN_PASSWORD=

# Senhas opcionais para usuários pré-configurados.
NEUSA_PASSWORD=
SECRETARIA_PASSWORD=
ROCHE_PASSWORD=

# -----------------------------------------------------------------------------
# 3) BANCO DE DADOS DO DASHBOARD (PostgreSQL externo)
# -----------------------------------------------------------------------------
# Banco dedicado do dashboard. Todos os campos são obrigatórios.
DATABASE_NAME=siscan_dashboard
DATABASE_USER=siscan_dashboard
DATABASE_PASSWORD=
DATABASE_PORT=5432
# IP ou hostname do servidor PostgreSQL. NÃO use 'db'.
DATABASE_HOST=

# -----------------------------------------------------------------------------
# 4) BANCO DE DADOS DO RPA (fonte dos dados de exames)
# -----------------------------------------------------------------------------
# Conexão ao banco do siscan-rpa para o sync incremental.
# Formato: postgresql://usuario:senha@host:porta/banco
# Exemplo: postgresql://siscan_rpa:senha@192.168.1.10:5432/siscan_rpa
RPA_DATABASE_URL=

# -----------------------------------------------------------------------------
# 5) POOL DE CONEXÕES SQLAlchemy
# -----------------------------------------------------------------------------
SQLALCHEMY_POOL_SIZE=5
SQLALCHEMY_MAX_OVERFLOW=2
SQLALCHEMY_POOL_TIMEOUT=30
SQLALCHEMY_POOL_RECYCLE=300

# -----------------------------------------------------------------------------
# 6) SINCRONIZAÇÃO
# -----------------------------------------------------------------------------
# Intervalo em segundos entre ciclos de sync. 1800 = 30 minutos.
SYNC_INTERVAL_SECONDS=1800

# -----------------------------------------------------------------------------
# 7) PERSISTÊNCIA NO HOST — bind mounts
# -----------------------------------------------------------------------------
# Logs da aplicação e do sync.
HOST_LOG_DIR=/opt/siscan-dashboard/logs

# -----------------------------------------------------------------------------
# 8) OPCIONAL
# -----------------------------------------------------------------------------
# Timezone operacional. Omita para usar o padrão (America/Sao_Paulo).
# TZ=America/Sao_Paulo
