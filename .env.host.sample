# =============================================================================
# SISCAN RPA — Assistente de Instalação — Sample do .env (modo HOST / PC local)
# =============================================================================
# Copie este arquivo para `.env` na mesma pasta e preencha os valores antes
# de executar o assistente pela primeira vez.
#
# Modo coberto: HOST — docker-compose.prd.host.yml
#   - Banco de dados PostgreSQL em container local (serviço `db` na stack)
#   - Executado via siscan-assistente.ps1 (Windows) ou siscan-assistente.sh (Linux)
#
# Para o modo SERVIDOR (Ubuntu + PostgreSQL externo), use .env.server.sample.
#
# Convenção:
#   HOST_* = caminhos reais no sistema de arquivos do computador (host)
#   demais  = parâmetros de runtime passados aos containers
#
# Windows: use barras invertidas (C:\siscan-rpa\logs)
# Linux:   use barras normais    (/opt/siscan-rpa/logs)
# =============================================================================

# -----------------------------------------------------------------------------
# 1) APLICAÇÃO HTTP
# -----------------------------------------------------------------------------
# Porta TCP acessada no navegador. Ex.: http://localhost:5001
HOST_APP_EXTERNAL_PORT=5001

# Nível de log. Use INFO em produção; DEBUG apenas para diagnóstico temporário.
# Valores: DEBUG, INFO, WARNING, ERROR
APP_LOG_LEVEL=INFO

# Workers Gunicorn do container app.
# Modo HOST (~4 vCPU compartilhados com o Chromium do rpa-scheduler): use 2.
WEB_CONCURRENCY=2

# Chave de assinatura de sessão web. Obrigatória.
# O assistente gera automaticamente na primeira execução.
# Para gerar manualmente: openssl rand -hex 32
SECRET_KEY=

# -----------------------------------------------------------------------------
# 2) BANCO DE DADOS (PostgreSQL gerenciado pelo Docker — modo HOST)
# -----------------------------------------------------------------------------
# Altere DATABASE_PASSWORD antes de subir pela primeira vez.
DATABASE_NAME=siscan_rpa
DATABASE_USER=siscan_rpa
DATABASE_PASSWORD=siscan_rpa
DATABASE_PORT=5432
# No modo HOST o banco roda no mesmo Docker stack — não altere este valor.
DATABASE_HOST=db

# -----------------------------------------------------------------------------
# 3) POOL DE CONEXÕES SQLAlchemy
# -----------------------------------------------------------------------------
# POOL_SIZE deve ser >= workers efetivos do processar_laudos.
# Com 4 vCPUs: workers = min(max(4,2), 8) = 4 → usar 4.
SQLALCHEMY_POOL_SIZE=4
# Conexões extras temporárias (absorvem picos). Banco local: manter em 1.
SQLALCHEMY_MAX_OVERFLOW=1
# Segundos para aguardar conexão livre antes de falhar.
SQLALCHEMY_POOL_TIMEOUT=30
# Vida máxima de uma conexão em segundos (evita conexões mortas por NAT/idle).
SQLALCHEMY_POOL_RECYCLE=1800

# -----------------------------------------------------------------------------
# 4) SCHEDULER BATCH
# -----------------------------------------------------------------------------
# Habilita o container rpa-scheduler. false = container sobe mas não executa.
CRON_ENABLED=true
# Intervalo entre execuções em segundos. 1800 = 30 minutos.
CRON_INTERVAL_SECONDS=1800
# Tentativas máximas em falhas transitórias (1 inicial + N-1 repetições).
RPA_MAX_ATTEMPTS=3

# -----------------------------------------------------------------------------
# 5) PERSISTÊNCIA NO HOST — bind mounts (obrigatórios)
# -----------------------------------------------------------------------------
# Todos os diretórios abaixo serão criados pelo assistente se não existirem.
#
# Estrutura sugerida (Windows):
#   C:\siscan-rpa\
#   ├── logs\                      ← HOST_LOG_DIR
#   ├── config\                    ← HOST_CONFIG_DIR
#   ├── media\downloads\           ← HOST_SISCAN_REPORTS_INPUT_DIR
#   ├── media\reports\...\         ← HOST_REPORTS_OUTPUT_CONSOLIDATED_DIR
#   ├── media\reports\...\laudos\  ← HOST_REPORTS_OUTPUT_CONSOLIDATED_PDFS_DIR
#   ├── scripts\clients\           ← HOST_SCRIPTS_CLIENTS
#   └── backups\                   ← HOST_BACKUPS_DIR
#
# Para Linux, substitua C:\siscan-rpa\ por /opt/siscan-rpa/ e \ por /.

# Logs da aplicação e do scheduler. Inclua na rotina de backup.
HOST_LOG_DIR=C:\siscan-rpa\logs

# PDFs baixados do SISCAN. Entrada do pipeline processar_laudos.
HOST_SISCAN_REPORTS_INPUT_DIR=C:\siscan-rpa\media\downloads

# Artefatos consolidados: .xlsx, .parquet.
HOST_REPORTS_OUTPUT_CONSOLIDATED_DIR=C:\siscan-rpa\media\reports\mamografia\consolidated

# PDFs individuais por laudo, organizados em subpastas por status.
HOST_REPORTS_OUTPUT_CONSOLIDATED_PDFS_DIR=C:\siscan-rpa\media\reports\mamografia\consolidated\laudos

# Arquivos de configuração externos (ex.: excel_columns_mapping.json).
HOST_CONFIG_DIR=C:\siscan-rpa\config

# Scripts operacionais do operador (ex.: backup_manager.sh).
HOST_SCRIPTS_CLIENTS=C:\siscan-rpa\scripts\clients

# Destino dos backups do PostgreSQL gerados por backup_manager.sh.
HOST_BACKUPS_DIR=C:\siscan-rpa\backups

# -----------------------------------------------------------------------------
# 6) OPCIONAL
# -----------------------------------------------------------------------------
# Timezone do scheduler e dos contextos Playwright.
# Omita para usar o padrão (America/Fortaleza).
# PW_CONTEXT_TIMEZONE=America/Fortaleza

# Persiste/reutiliza o storage state de autenticação do Playwright.
# true = reutiliza sessão (recomendado); false = sessão isolada a cada execução.
PW_CONTEXT_STORAGE_STATE_STRICT=true

# Nome do JSON de mapeamento de colunas dentro de HOST_CONFIG_DIR.
# Omita para usar o padrão: excel_columns_mapping.json
# HOST_SHEET_COLUMNS_MAPPING_NAME=meu_mapeamento_excel.json

# Nome alternativo do XLSX consolidado gerado no diretório de saída.
# SISCAN_CONSOLIDATED_SHEET_NAME=consolidated_report_results_default.xlsx

# -----------------------------------------------------------------------------
# 7) DASHBOARD — painel analítico (modo HOST)
# -----------------------------------------------------------------------------
# Porta TCP do dashboard. URL: http://localhost:5000
HOST_DASHBOARD_EXTERNAL_PORT=5000

# Nome do banco do dashboard (criado automaticamente pelo init script).
DASHBOARD_DATABASE_NAME=siscan_dashboard

# Chave de sessão do dashboard. Se omitida, usa SECRET_KEY.
# DASHBOARD_SESSION_SECRET=

# Senha do admin do dashboard.
DASHBOARD_ADMIN_PASSWORD=

# Workers Gunicorn do dashboard. Modo HOST: use 2.
DASHBOARD_WEB_CONCURRENCY=2

# Intervalo de sincronização RPA → dashboard em segundos. 1800 = 30 min.
SYNC_INTERVAL_SECONDS=1800

# Diretório de logs do dashboard.
HOST_DASHBOARD_LOG_DIR=C:\siscan-rpa\logs\dashboard

# Senhas opcionais para usuários pré-configurados do dashboard.
# DASHBOARD_NEUSA_PASSWORD=
# DASHBOARD_SECRETARIA_PASSWORD=
# DASHBOARD_ROCHE_PASSWORD=

# Produto gerenciado por esta instalação do assistente.
SISCAN_PRODUCT=full

# =============================================================================
