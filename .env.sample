###########################################################################
# Copie este arquivo para `.env` e preencha os valores abaixo.
# Convenção:
# - HOST_* = caminhos reais do host onde os dados serão persistidos
# - variáveis sem HOST_* = parâmetros de runtime da aplicação
###########################################################################

######################### 1) CONFIGURAÇÃO DO APLICATIVO #########################
# Porta externa que o usuário acessa (ex.: 5001). Se houver proxy, ajuste.
HOST_APP_EXTERNAL_PORT=5001

# Nível de log da aplicação. Use INFO em produção; DEBUG para diagnóstico.
# Valores aceitos: DEBUG, INFO, WARNING, ERROR
APP_LOG_LEVEL=INFO

# Número de workers HTTP. Para SQLite em produção, prefira 1 (evita contenção de escrita).
WEB_CONCURRENCY=1

######################### 2) CREDENCIAIS SISCAN ################################
# As credenciais do SISCAN são configuradas via interface administrativa após
# a primeira inicialização: acesse http://localhost:<HOST_APP_EXTERNAL_PORT>/admin/siscan-credentials
# Não são necessárias no .env em produção.

######################### 3) PERSISTÊNCIA NO HOST ##############################
# Caminhos completos no host onde os dados serão armazenados.
# O assistente cria os diretórios e o arquivo de banco automaticamente.

# Arquivo SQLite do banco de dados.
# Importante: deve ser um arquivo, não um diretório.
HOST_DATABASE_PATH=/opt/siscan-rpa/data/database.db

# Diretório de logs da aplicação e do scheduler.
HOST_LOG_DIR=/opt/siscan-rpa/logs

# Diretório dos PDFs-fonte baixados do SISCAN (entrada do processamento).
HOST_SISCAN_REPORTS_INPUT_DIR=/opt/siscan-rpa/media/downloads

# Diretório dos artefatos consolidados (Excel, Parquet).
HOST_REPORTS_OUTPUT_CONSOLIDATED_DIR=/opt/siscan-rpa/media/reports/mamografia/consolidated

# Diretório dos PDFs individuais exportados por laudo/protocolo.
HOST_REPORTS_OUTPUT_CONSOLIDATED_PDFS_DIR=/opt/siscan-rpa/media/reports/mamografia/consolidated/laudos

# Diretório de configuração externa (ex.: JSON de mapeamento de colunas do Excel).
HOST_CONFIG_DIR=/opt/siscan-rpa/config

######################### 4) AGENDAMENTO / CRON ###############################
# Intervalo em segundos entre execuções agendadas (ex.: 1800 = 30 minutos)
CRON_INTERVAL_SECONDS=1800

######################### 5) RETRIES / TENTATIVAS #############################
# Número máximo de tentativas quando algo falha (ex.: falha de rede)
RPA_MAX_ATTEMPTS=3

######################### 6) SEGURANÇA #########################################
# Chave de assinatura de sessão web. Gerada automaticamente pelo assistente.
# Para gerar manualmente: openssl rand -hex 32
SECRET_KEY=

###########################################################################
