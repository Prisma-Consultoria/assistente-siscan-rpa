# =============================================================================
# SISCAN RPA — Assistente de Instalação — Sample do .env (modo SERVIDOR)
# =============================================================================
# Utilizado pelo siscan-server-setup.sh na fase 4 para criar o .env inicial.
# Após o script, edite o arquivo gerado em /opt/siscan-rpa/.env.
#
# Modo coberto: SERVIDOR — docker-compose.prd.rpa.yml
#   - Sem serviço `db` local; conecta ao PostgreSQL externo via DATABASE_HOST
#   - Deploy automático via GitHub Actions self-hosted runner (Opção 1.A)
#
# Para o modo HOST (PC local com Docker Desktop), use .env.host.sample.
#
# Convenção:
#   HOST_* = caminhos absolutos Linux no servidor (ex.: /opt/siscan-rpa/logs)
#   demais  = parâmetros de runtime passados aos containers
# =============================================================================

# -----------------------------------------------------------------------------
# 1) APLICAÇÃO HTTP
# -----------------------------------------------------------------------------
# Porta TCP publicada no host. URL de acesso: http://<IP-DO-SERVIDOR>:5001
HOST_APP_EXTERNAL_PORT=5001

# Nível de log. Use INFO em produção; DEBUG apenas para diagnóstico temporário.
# Valores: DEBUG, INFO, WARNING, ERROR
APP_LOG_LEVEL=INFO

# Workers Gunicorn do container app.
# Servidor dedicado com 4 vCPUs: use 4 (1 worker/vCPU).
# O compose prd.external-db.yml usa 4 como fallback se omitido.
WEB_CONCURRENCY=4

# Chave de assinatura de sessão web. Obrigatória — sem fallback no compose.
# O siscan-server-setup.sh gera automaticamente com: openssl rand -hex 32
SECRET_KEY=

# -----------------------------------------------------------------------------
# 2) BANCO DE DADOS (PostgreSQL externo — não há serviço `db` nesta stack)
# -----------------------------------------------------------------------------
# DATABASE_HOST é obrigatório e não tem fallback no compose.
# O container falha no boot se este valor estiver vazio.
DATABASE_NAME=siscan_rpa
DATABASE_USER=siscan_rpa
# Altere DATABASE_PASSWORD antes de subir pela primeira vez.
DATABASE_PASSWORD=siscan_rpa
DATABASE_PORT=5432
# IP ou hostname do servidor PostgreSQL externo. Exemplo: 192.168.1.10
# NÃO use 'db' — não há container de banco nesta stack.
DATABASE_HOST=

# -----------------------------------------------------------------------------
# 3) POOL DE CONEXÕES SQLAlchemy
# -----------------------------------------------------------------------------
# POOL_SIZE deve ser >= workers efetivos do processar_laudos.
# Com 4 vCPUs: workers = min(max(4,2), 8) = 4 → usar 4.
# Total de conexões no banco: 4×(4+2) [app] + 1×(4+2) [rpa-scheduler] = 30.
SQLALCHEMY_POOL_SIZE=4
# Conexões extras temporárias. Banco externo dedicado: use 2.
SQLALCHEMY_MAX_OVERFLOW=2
# Segundos para aguardar conexão livre antes de falhar.
SQLALCHEMY_POOL_TIMEOUT=30
# Vida máxima de uma conexão em segundos (evita conexões mortas por NAT/idle).
SQLALCHEMY_POOL_RECYCLE=1800

# -----------------------------------------------------------------------------
# 4) SCHEDULER BATCH
# -----------------------------------------------------------------------------
# Habilita o container rpa-scheduler. false = container sobe mas não executa.
CRON_ENABLED=true
# Intervalo entre execuções em segundos. 1800 = 30 minutos.
CRON_INTERVAL_SECONDS=1800
# Tentativas máximas em falhas transitórias (1 inicial + N-1 repetições).
RPA_MAX_ATTEMPTS=3

# -----------------------------------------------------------------------------
# 5) PERSISTÊNCIA NO HOST — bind mounts (obrigatórios)
# -----------------------------------------------------------------------------
# Use caminhos Linux absolutos. O siscan-server-setup.sh cria os diretórios
# automaticamente na fase 5 a partir dos valores definidos abaixo.
#
# Estrutura sugerida em /opt/siscan-rpa/:
#   /opt/siscan-rpa/
#   ├── logs/                      ← HOST_LOG_DIR
#   ├── config/                    ← HOST_CONFIG_DIR
#   ├── media/downloads/           ← HOST_SISCAN_REPORTS_INPUT_DIR
#   ├── media/reports/.../         ← HOST_REPORTS_OUTPUT_CONSOLIDATED_DIR
#   ├── media/reports/.../laudos/  ← HOST_REPORTS_OUTPUT_CONSOLIDATED_PDFS_DIR
#   ├── scripts/clients/           ← HOST_SCRIPTS_CLIENTS
#   └── backups/                   ← HOST_BACKUPS_DIR

# Logs da aplicação e do scheduler. Inclua na rotina de backup.
HOST_LOG_DIR=/opt/siscan-rpa/logs

# PDFs baixados do SISCAN. Entrada do pipeline processar_laudos.
HOST_SISCAN_REPORTS_INPUT_DIR=/opt/siscan-rpa/media/downloads

# Artefatos consolidados: .xlsx, .parquet.
HOST_REPORTS_OUTPUT_CONSOLIDATED_DIR=/opt/siscan-rpa/media/reports/mamografia/consolidated

# PDFs individuais por laudo, organizados em subpastas por status.
HOST_REPORTS_OUTPUT_CONSOLIDATED_PDFS_DIR=/opt/siscan-rpa/media/reports/mamografia/consolidated/laudos

# Arquivos de configuração externos (ex.: excel_columns_mapping.json).
HOST_CONFIG_DIR=/opt/siscan-rpa/config

# Scripts operacionais do operador (ex.: backup_manager.sh).
HOST_SCRIPTS_CLIENTS=/opt/siscan-rpa/scripts/clients

# Destino dos backups do PostgreSQL gerados por backup_manager.sh.
HOST_BACKUPS_DIR=/opt/siscan-rpa/backups

# -----------------------------------------------------------------------------
# 6) OPCIONAL
# -----------------------------------------------------------------------------
# Timezone do scheduler e dos contextos Playwright.
# Omita para usar o padrão (America/Fortaleza).
# PW_CONTEXT_TIMEZONE=America/Fortaleza

# Persiste/reutiliza o storage state de autenticação do Playwright.
# true = reutiliza sessão (recomendado); false = sessão isolada a cada execução.
PW_CONTEXT_STORAGE_STATE_STRICT=true

# Nome do JSON de mapeamento de colunas dentro de HOST_CONFIG_DIR.
# Omita para usar o padrão: excel_columns_mapping.json
# HOST_SHEET_COLUMNS_MAPPING_NAME=meu_mapeamento_excel.json

# Nome alternativo do XLSX consolidado gerado no diretório de saída.
# SISCAN_CONSOLIDATED_SHEET_NAME=consolidated_report_results_default.xlsx

# =============================================================================
